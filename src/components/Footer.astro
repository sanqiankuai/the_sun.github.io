---
import { SITE_TITLE } from '../consts';
const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} {SITE_TITLE}. Powered by <a href="https://astro.build" target="_blank">Astro</a></p>
	<p class="links">
		<a href="/">首页</a>
		<a href="/archives">归档</a>
		<a href="/moments">瞬间</a>
		<a href="/gallery">图库</a>
		<a href="/rss.xml">RSS</a>
	</p>
</footer>

<style>
	footer {
		padding: 1.25rem 1rem;
		background: var(--bg-secondary);
		color: var(--text-secondary);
		text-align: center;
	}
	
	@media (min-width: 768px) {
		footer {
			padding: 1.75rem 1.5rem;
		}
	}
	
	@media (min-width: 1024px) {
		footer {
			padding: 2.5rem 2rem;
		}
	}
	
	@media (min-width: 1280px) {
		footer {
			padding: 3rem 2.5rem;
		}
	}
	
	footer p {
		margin: 0.375rem 0;
	}
	
	@media (min-width: 768px) {
		footer p {
			margin: 0.5rem 0;
		}
	}
	
	footer a {
		color: var(--accent);
		text-decoration: none;
	}
	
	.links {
		display: flex;
		justify-content: center;
		gap: 0.625rem;
		flex-wrap: wrap;
		font-size: 0.8rem;
	}
	
	@media (min-width: 768px) {
		.links {
			gap: 1rem;
			font-size: 0.9rem;
		}
	}
	
	@media (min-width: 1024px) {
		.links {
			gap: 1.25rem;
			font-size: 1rem;
		}
	}
	
	.links a {
		color: var(--text-secondary);
	}
	
	.links a:hover {
		color: var(--accent);
	}
</style>