---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

const moments = (await getCollection('moments')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const allTags = moments
	.flatMap((m) => m.data.tags || [])
	.reduce((acc, tag) => {
		acc[tag] = (acc[tag] || 0) + 1;
		return acc;
	}, {} as Record<string, number>);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`瞬间 | ${SITE_TITLE}`} description="我的瞬间" />
	</head>
	<body>
		<Header />
		<main>
			<h1>瞬间</h1>
			<a href="/rss.xml" class="rss-link">RSS 订阅</a>
			
			<div class="tags-filter">
				{Object.entries(allTags).map(([tag, count]) => (
					<span class="tag">{tag} ({count})</span>
				))}
			</div>

			<div class="moments-list">
				{moments.map((moment) => (
					<article class="moment-card">
						<div class="moment-header">
							<img src="/images/avatar.jpg" alt="Avatar" class="moment-avatar" />
							<span class="moment-author">{SITE_TITLE}</span>
							<span class="moment-date">
								<FormattedDate date={moment.data.date} />
							</span>
						</div>
						<div class="moment-content">
							<p>{moment.body}</p>
							{moment.data.image && (
								<img src={moment.data.image} alt="Moment image" class="moment-image" />
							)}
						</div>
						<div class="moment-tags">
							{moment.data.tags?.map((tag) => (
								<span class="tag">{tag}</span>
							))}
						</div>
					</article>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.rss-link {
		display: inline-block;
		margin-bottom: 0.75rem;
		color: var(--accent);
		font-size: 0.9rem;
	}
	
	@media (min-width: 768px) {
		.rss-link {
			margin-bottom: 1rem;
			font-size: 1rem;
		}
	}
	
	.tags-filter {
		display: flex;
		gap: 0.375rem;
		flex-wrap: wrap;
		margin-bottom: 1.5rem;
	}
	
	@media (min-width: 768px) {
		.tags-filter {
			gap: 0.5rem;
			margin-bottom: 2rem;
		}
	}
	
	.tag {
		background: var(--bg-tertiary);
		padding: 0.2rem 0.6rem;
		border-radius: 4px;
		font-size: 0.75rem;
		color: var(--text-secondary);
	}
	
	@media (min-width: 768px) {
		.tag {
			padding: 0.25rem 0.75rem;
			font-size: 0.85rem;
		}
	}
	
	.moments-list {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	
	@media (min-width: 768px) {
		.moments-list {
			gap: 1.5rem;
		}
	}
	
	.moment-card {
		background: var(--card-bg);
		border-radius: 10px;
		padding: 1rem;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
	}
	
	@media (min-width: 768px) {
		.moment-card {
			border-radius: 12px;
			padding: 1.5rem;
		}
	}
	
	@media (min-width: 1024px) {
		.moment-card {
			padding: 2rem;
		}
	}
	
	.moment-header {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 0.75rem;
	}
	
	@media (min-width: 768px) {
		.moment-header {
			gap: 0.75rem;
			margin-bottom: 1rem;
		}
	}
	
	.moment-avatar {
		width: 32px;
		height: 32px;
		border-radius: 50%;
		object-fit: cover;
	}
	
	@media (min-width: 768px) {
		.moment-avatar {
			width: 40px;
			height: 40px;
		}
	}
	
	@media (min-width: 1024px) {
		.moment-avatar {
			width: 48px;
			height: 48px;
		}
	}
	
	.moment-author {
		font-weight: 600;
		color: var(--text-primary);
		font-size: 0.9rem;
	}
	
	@media (min-width: 768px) {
		.moment-author {
			font-size: 1rem;
		}
	}
	
	.moment-date {
		color: var(--text-secondary);
		font-size: 0.75rem;
		margin-left: auto;
	}
	
	@media (min-width: 768px) {
		.moment-date {
			font-size: 0.85rem;
		}
	}
	
	.moment-content p {
		margin: 0;
		line-height: 1.5;
		color: var(--text-secondary);
		font-size: 0.9rem;
	}
	
	@media (min-width: 768px) {
		.moment-content p {
			line-height: 1.6;
			font-size: 1rem;
		}
	}
	
	.moment-image {
		width: 100%;
		max-width: 100%;
		border-radius: 6px;
		margin-top: 0.75rem;
	}
	
	@media (min-width: 768px) {
		.moment-image {
			max-width: 400px;
			border-radius: 8px;
			margin-top: 1rem;
		}
	}
	
	@media (min-width: 1024px) {
		.moment-image {
			max-width: 500px;
		}
	}
	
	.moment-tags {
		display: flex;
		gap: 0.375rem;
		margin-top: 0.75rem;
	}
	
	@media (min-width: 768px) {
		.moment-tags {
			gap: 0.5rem;
			margin-top: 1rem;
		}
	}
	
	.moment-tags .tag {
		background: var(--accent);
		color: white;
	}
</style>